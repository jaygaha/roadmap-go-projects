# Application Configuration
APP_PORT=8800

# Database Configuration
MONGO_IMAGE=8
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root@123
MONGO_INITDB_DATABASE=image_processing
MONGO_PORT=27017
MONGODB_URI="mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:${MONGO_PORT}/${MONGO_INITDB_DATABASE}"

# AWS/LocalStack Configuration
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=1
LOCALSTACK_SERVICES=s3 # comma separated list of services to run s3,sqs
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=img-bucket
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT="http://localstack:${LOCALSTACK_PORT}"
